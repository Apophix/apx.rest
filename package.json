{
	"name": "apx.rest",
	"version": "1.2.3",
	"description": "TypeScript code generation tool for REST APIs",
	"type": "module",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/Apophix/apx.rest"
	},
	"exports": {
		".": {
			"import": "./dist/src/index.js",
			"types": "./dist/src/index.d.ts"
		}
	},
	"bin": {
		"apx-gen": "./dist/codegen.js"
	},
	"files": [
		"dist/",
		"README.md"
	],
	"scripts": {
		"build": "tsc -p ./tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"release": "changeset publish --provenance",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"codegen",
		"typescript",
		"api",
		"rest"
	],
	"author": "Apophix",
	"license": "ISC",
	"dependencies": {
		"chalk": "^5",
		"tsx": "^4"
	},
	"overrides": {
		"esbuild": "^0.28.1",
		"vite": "^8.0.16"
	},
	"devDependencies": {
		"@changesets/cli": "^2",
		"@types/node": "^20",
		"typescript": "^5",
		"vitest": "^4.1.4"
	}
}
